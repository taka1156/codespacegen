{
    "$schema": "https://raw.githubusercontent.com/taka1156/codespacegen/refs/heads/master/codespacegen.schema.json",
    "common": {
        "timezone": "Asia/Tokyo",
        "vscodeExtensions": [
            "MS-CEINTL.vscode-language-pack-ja",
            "GitHub.copilot",
            "streetsidesoftware.code-spell-checker",
            "username.errorlens"
        ]
    },
    "go": {
        "image": "golang:1.24-alpine",
        "vscodeExtensions": [
            "golang.Go"
        ]
    },
    "python": {
        "image": "python:3.12-alpine",
        "vscodeExtensions": [
            "ms-python.python"
        ]
    },
    "node:biome": {
        "image": "node:22-alpine",
        "vscodeExtensions": [
            "biomejs.biome"
        ]
    },
    "node:eslint": {
        "image": "node:22-alpine",
        "vscodeExtensions": [
            "dbaeumer.vscode-eslint",
            "esbenp.prettier-vscode"
        ]
    },
    "node:react": {
        "image": "node:22-alpine",
        "vscodeExtensions": [
            "jawandarajbir.react-vscode-extension-pack",
            "dbaeumer.vscode-eslint",
            "stylelint.vscode-stylelint",
            "esbenp.prettier-vscode"
        ]
    },
    "rust": {
        "image": "rust:1-alpine",
        "vscodeExtensions": [
            "Zerotaskx.rust-extension-pack"
        ]
    },
    "moonbit": {
        "image": "ubuntu:24.04",
        "install": "curl -fsSL https://cli.moonbitlang.com/install/unix.sh | bash",
        "vscodeExtensions": [
            "moonbit.moonbit-lang"
        ]
    }
}
