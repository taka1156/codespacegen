{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/taka1156/codespacegen/master/codespacegen.schema.json",
  "title": "codespacegen image config",
  "description": "Configuration for common defaults and language-specific overrides used by codespacegen -image-config.",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional schema URI for editor validation."
    },
    "common": {
      "$ref": "#/$defs/commonEntry",
      "description": "Base settings applied to all languages. Language-specific settings take precedence."
    },
    "langs": {
      "type": "array",
      "description": "Language-specific configuration entries.",
      "items": {
        "$ref": "#/$defs/langEntry"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "commonEntry": {
      "type": "object",
      "properties": {
        "timezone": {
          "type": "string",
          "description": "Default timezone for this entry (e.g. UTC, Asia/Tokyo)."
        },
        "locale": {
          "type": "object",
          "description": "OS locale settings for the container.",
          "properties": {
            "lang": {
              "type": "string",
              "description": "LANG environment variable (e.g. ja_JP.UTF-8)."
            },
            "language": {
              "type": "string",
              "description": "LANGUAGE environment variable (e.g. ja_JP:ja)."
            },
            "lcAll": {
              "type": "string",
              "description": "LC_ALL environment variable (e.g. ja_JP.UTF-8)."
            }
          },
          "additionalProperties": false
        },
        "vscodeExtensions": {
          "type": "array",
          "description": "VS Code extension IDs (e.g. golang.Go).",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "langEntry": {
      "type": "object",
      "required": [
        "profileName"
      ],
      "properties": {
        "profileName": {
          "type": "string",
          "minLength": 1,
          "description": "Language identifier key (e.g. go, python, node:eslint)."
        },
        "image": {
          "type": "string",
          "description": "Base image name. If omitted while runCommand is set, codespacegen uses alpine:latest."
        },
        "runCommand": {
          "type": "string",
          "description": "Injected as RUN in Dockerfile."
        },
        "linuxPackages": {
          "type": "array",
          "description": "List of Linux system packages to install (e.g. make, git). Used for apt, apk, etc.",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "vscodeExtensions": {
          "type": "array",
          "description": "VS Code extension IDs (e.g. golang.Go).",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    }
  },
  "examples": [
    {
      "$schema": "https://raw.githubusercontent.com/taka1156/codespacegen/refs/heads/master/codespacegen.schema.json",
      "common": {
        "timezone": "Asia/Tokyo",
        "vscodeExtensions": [
          "MS-CEINTL.vscode-language-pack-ja",
          "streetsidesoftware.code-spell-checker"
        ]
      },
      "langs": [
        {
          "profileName": "go",
          "image": "golang:1.24-alpine",
          "vscodeExtensions": [
            "golang.Go"
          ]
        },
        {
          "profileName": "moonbit",
          "image": "ubuntu:24.04",
          "runCommand": "curl -fsSL https://cli.moonbitlang.com/install/unix.sh | bash",
          "vscodeExtensions": [
            "moonbit.moonbit-lang"
          ]
        }
      ]
    }
  ]
}
