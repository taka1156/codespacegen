{
  "$schema": "https://raw.githubusercontent.com/taka1156/codespacegen/refs/heads/master/codespacegen.schema.json",
  "common": {
    "locale": {
      "lang": "en.UTF-8",
      "language": "en_US:en",
      "lcAll": "en.UTF-8"
    },
    "timezone": "Asia/Tokyo",
    "vscodeExtensions": [
      "MS-CEINTL.vscode-language-pack-ja",
      "GitHub.copilot",
      "GitHub.copilot-chat",
      "streetsidesoftware.code-spell-checker",
      "username.errorlens"
    ]
  },
  "go": {
    "image": "golang:1.24-alpine",
    "vscodeExtensions": [
      "golang.Go"
    ]
  },
  "python": {
    "image": "python:3.12-alpine",
    "vscodeExtensions": [
      "ms-python.python"
    ]
  },
  "node:biome": {
    "image": "node:22-alpine",
    "vscodeExtensions": [
      "biomejs.biome"
    ]
  },
  "node:eslint": {
    "image": "node:22-alpine",
    "vscodeExtensions": [
      "dbaeumer.vscode-eslint",
      "esbenp.prettier-vscode"
    ]
  },
  "node:react": {
    "image": "node:22-alpine",
    "vscodeExtensions": [
      "jawandarajbir.react-vscode-extension-pack",
      "dbaeumer.vscode-eslint",
      "stylelint.vscode-stylelint",
      "esbenp.prettier-vscode"
    ]
  },
  "rust": {
    "image": "rust:1-alpine",
    "vscodeExtensions": [
      "Zerotaskx.rust-extension-pack"
    ]
  },
  "moonbit": {
    "image": "ubuntu:24.04",
    "runCommand": "curl -fsSL https://cli.moonbitlang.com/install/unix.sh | bash",
    "vscodeExtensions": [
      "moonbit.moonbit-lang"
    ]
  },
  "gcc": {
    "image": "ubuntu:24.04",
    "linuxPackages": [
      "gcc",
      "make",
      "binutils",
      "libc6-dev"
    ],
    "vscodeExtensions": [
      "ms-vscode.cpptools"
    ]
  },
  "node:zenn": {
    "image": "node:24-alpine",
    "runCommand": "yarn global add zenn-cli",
    "vscodeExtensions": [
      "zenn.zenn-vscode-extension"
    ]
  }
}
